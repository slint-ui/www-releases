{
  "name": "ui-testing-site",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "scripts/dev.sh",
    "deploy": "wrangler deploy",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "test/e2e/run.sh",
    "typecheck": "tsc --noEmit",
    "db:migrate:local": "wrangler d1 migrations apply ui-testing --local",
    "db:migrate:remote": "wrangler d1 migrations apply ui-testing --remote",
    "tokens:list": "wrangler d1 execute ui-testing --remote --command \"SELECT token, customer, datetime(created_at, 'unixepoch') AS created, datetime(revoked_at, 'unixepoch') AS revoked, datetime(last_used_at, 'unixepoch') AS last_used FROM tokens ORDER BY created_at DESC;\"",
    "tokens:issue": "tsx scripts/issue-token.ts",
    "tokens:revoke": "tsx scripts/revoke-token.ts",
    "publish:package": "scripts/publish.sh",
    "yank": "scripts/yank.sh"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "workerd"
    ]
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.16.8",
    "@cloudflare/workers-types": "^4.20260522.1",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vite": "^8.0.14",
    "vitest": "4.1.7",
    "wrangler": "^4.93.1"
  }
}
